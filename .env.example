# ─────────────────────────────────────────────────────────────
# Supabase
# 프로젝트 대시보드 > Project Settings > API 에서 값을 복사한다.
# 클론 후 이 파일을 `.env.local` 로 복사하여 실제 값을 채운다.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# 서버 전용 시크릿 키 (service_role). 절대 클라이언트에 노출 금지.
# 필요할 때만 주석을 해제하여 사용한다.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# Drizzle ORM (Postgres 직접 연결)
# Supabase 대시보드 > Project Settings > Database > Connection string 에서 복사한다.
# - 서버리스/풀링 권장: "Transaction pooler" (포트 6543) 문자열 사용
#   이 경우 lib/db/index.ts 의 postgres 클라이언트가 prepare:false 로 동작한다.
# - 마이그레이션(db:migrate/db:push) 시에는 "Session"/"Direct" 연결도 사용 가능
# [YOUR-PASSWORD] 자리에 DB 비밀번호를 넣고, 비밀번호의 특수문자는 URL 인코딩한다.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres
