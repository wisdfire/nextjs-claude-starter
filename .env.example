# ─────────────────────────────────────────────────────────────
# Neon Postgres (https://console.neon.tech)
# 클론 후 이 파일을 `.env.local` 로 복사하여 실제 값을 채운다.
#   cp .env.example .env.local
#
# 연결 문자열은 Neon CLI 출력을 **그대로 붙여넣는다**. 손으로 조립하지 말 것 —
# 호스트에 `.c-N.` 세그먼트가 들어가고 `channel_binding=require`가 붙는다.
#   neon connection-string --project-id <PROJECT_ID> --pooled   # → DATABASE_URL
#   neon connection-string --project-id <PROJECT_ID>            # → DIRECT_URL
# 또는 콘솔 > Project > Connection Details 에서 복사.
#
# 프로젝트 생성부터의 전체 절차: docs/guides/getting-started.md
# ─────────────────────────────────────────────────────────────

# 앱 런타임·빌드용 pooled 연결. 호스트명에 `-pooler`가 들어가는 것이 직결과의 유일한 차이.
# PgBouncer transaction 모드라 lib/db/index.ts 의 postgres 클라이언트가 prepare:false 로 동작한다.
DATABASE_URL=postgresql://neondb_owner:[YOUR-PASSWORD]@ep-xxxxxxxx-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# drizzle-kit(generate/migrate/push/studio) 전용 직결 연결(`-pooler` 없음).
# pooled 연결로 DDL을 실행하면 오류가 날 수 있어 분리한다.
# ※ 로컬 전용 — Vercel 등 배포 환경에는 DATABASE_URL 만 등록한다.
DIRECT_URL=postgresql://neondb_owner:[YOUR-PASSWORD]@ep-xxxxxxxx.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ─────────────────────────────────────────────────────────────
# 사이트 (NEXT_PUBLIC_ 접두어는 브라우저에 노출된다 — 시크릿 금지)
# ─────────────────────────────────────────────────────────────
# 서비스 정식 도메인. metadata의 metadataBase(정규 URL·OG·사이트맵 기준)에 사용.
# 비워두면 http://localhost:3000 로 폴백한다.
NEXT_PUBLIC_SITE_URL=
