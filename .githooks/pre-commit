#!/bin/sh
# 커밋 전 번역 동기화 훅
# ------------------------------------------------------------
# messages/ko.json(한국어 원본)이 스테이징된 커밋에서만 동작한다.
# ko 가 바뀌었으면 바뀐 키만 LLM으로 번역해 en.json 을 맞추고 함께 스테이징한다.
#
# 이 훅은 `npm install` 시 실행되는 prepare 스크립트가
# core.hooksPath 를 .githooks 로 지정하면서 활성화된다.
#
# 건너뛰려면: git commit --no-verify

set -e

# ko.json 이 이번 커밋에 포함되지 않았으면 할 일이 없다
if ! git diff --cached --name-only | grep -q '^messages/ko\.json$'; then
  exit 0
fi

echo "[i18n] messages/ko.json 변경 감지 — 영어 번역을 동기화한다."

# 이미 최신이면 LLM 을 부르지 않는다 (불필요한 비용·지연 방지)
if node scripts/i18n/check.mjs >/dev/null 2>&1; then
  echo "[i18n] 이미 최신이다 — 번역을 건너뛴다."
  exit 0
fi

# Claude Code CLI 가 없으면 조용히 통과시키지 않고 막는다.
# 통과시키면 번역이 빠진 채로 커밋돼 영어 화면에 원문 키가 노출된다.
if ! command -v claude >/dev/null 2>&1; then
  echo "[i18n] ❌ claude CLI 를 찾을 수 없어 자동 번역을 할 수 없다."
  echo "       Claude Code 를 설치하거나, messages/en.json 을 직접 채운 뒤 다시 커밋하라."
  echo "       현재 어긋난 항목:"
  node scripts/i18n/check.mjs || true
  exit 1
fi

# 바뀐 키만 번역한다. ICU 구조가 깨지면 translate.mjs 가 1 로 종료해 커밋이 중단된다.
if ! node scripts/i18n/translate.mjs; then
  echo "[i18n] ❌ 번역에 실패했다 — 커밋을 중단한다."
  exit 1
fi

# 번역 결과를 이번 커밋에 포함시킨다
git add messages/en.json messages/.translations.lock.json

echo "[i18n] ✅ messages/en.json 갱신 후 스테이징 완료."
echo "       ⚠️  자동 생성된 번역이다 — 커밋 전에 diff 를 확인하라: git diff --cached messages/en.json"
